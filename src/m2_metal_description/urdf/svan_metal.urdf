  <!-- RR foot -->
  <gazebo reference="foot_RR">
    <material>Gazebo/Black</material>
    <collision>
      <surface>
        <bounce>
          <restitution_coefficient>0</restitution_coefficient>
          <threshold>1e+06</threshold>
        </bounce>
        <friction>
          <torsional>
            <coefficient>0.3</coefficient>
          </torsional>
          <ode>
            <mu>100.0</mu>
            <mu2>50</mu2>
          </ode>
          <bullet>
            <rolling_friction>0.3</rolling_friction>
