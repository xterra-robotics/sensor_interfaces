      <kp2>42.415</kp2>
      <kd0>1</kd0>
      <kd1>1.5</kd1>
      <kd2>0.5</kd2>
      <!-- 
            <kp0>80</kp0>
            <kp1>40</kp1>
            <kp2>20</kp2>
            <kd0>1</kd0>
            <kd1>1</kd1>
            <kd2>0.5</kd2> -->
      <!-- 
            <kp0>200</kp0>
            <kp1>120</kp1>
            <kp2>60</kp2>
            <kd0>1</kd0>
            <kd1>1</kd1>
            <kd2>0.5</kd2> -->
      <!-- adding higher gains for the swing leg -->
      <kpsw0>300</kpsw0>
      <kpsw1>300</kpsw1>
      <kpsw2>300</kpsw2>
      <kdsw0>6</kdsw0>
      <kdsw1>6</kdsw1>
      <kdsw2>6</kdsw2>
    </plugin>
  </gazebo>
  <!-- IMU sensor -->
  <gazebo>
    <plugin filename="libgazebo_ros_imu.so" name="imu_sensor">
      <alwaysOn>true</alwaysOn>
      <bodyName>base</bodyName>
      <frameName>base</frameName>
      <topicName>/shvan/imu</topicName>
      <serviceName>imu_service</serviceName>
      <xyzOffset> 0 0 0 </xyzOffset>
      <rpyOffset> 0 0 0 </rpyOffset>
      <gaussianNoise>0.001</gaussianNoise>
      <updateRate>1000.0</updateRate>
    </plugin>
  </gazebo>
  <!-- joint and base sensor -->
  <gazebo>
    <plugin filename="libjoint_state_sensor.so" name="joint_state_sensor"/>
  </gazebo>
  <gazebo>
    <plugin filename="libbase_state_sensor.so" name="base_state_sensor"/>
  </gazebo>
  <!-- FR foot -->
  <gazebo reference="foot_FR">
    <material>Gazebo/Black</material>
    <collision>
      <surface>
        <bounce>
          <restitution_coefficient>0</restitution_coefficient>
          <threshold>1e+06</threshold>
        </bounce>
        <friction>
          <torsional>
            <coefficient>0.3</coefficient>
          </torsional>
          <ode>
            <mu>100.0</mu>
            <mu2>50</mu2>
          </ode>
          <bullet>
            <rolling_friction>0.3</rolling_friction>
            <friction2>50</friction2>
          </bullet>
        </friction>
        <contact>
          <bullet>
            <kp>30000.0</kp>
            <kd>1000.0</kd>
          </bullet>
          <ode>
            <kp>30000.0</kp>
            <kd>1000.0</kd>
          </ode>
        </contact>
      </surface>
    </collision>
  </gazebo>
  <!-- FL foot -->
  <gazebo reference="foot_FL">
    <material>Gazebo/Black</material>
    <collision>
      <surface>
        <bounce>
          <restitution_coefficient>0</restitution_coefficient>
          <threshold>1e+06</threshold>
        </bounce>
        <friction>
          <torsional>
            <coefficient>0.3</coefficient>
          </torsional>
          <ode>
            <mu>100.0</mu>
            <mu2>50</mu2>
          </ode>
          <bullet>
            <rolling_friction>0.3</rolling_friction>
            <friction2>50</friction2>
          </bullet>
        </friction>
        <contact>
          <bullet>
            <kp>30000.0</kp>
            <kd>1000.0</kd>
          </bullet>
          <ode>
            <kp>30000.0</kp>
            <kd>1000.0</kd>
          </ode>
        </contact>
      </surface>
    </collision>
  </gazebo>
  <!-- FL foot -->
  <gazebo reference="foot_RL">
    <material>Gazebo/Black</material>
    <collision>
      <surface>
        <bounce>
          <restitution_coefficient>0</restitution_coefficient>
          <threshold>1e+06</threshold>
        </bounce>
        <friction>
          <torsional>
            <coefficient>0.3</coefficient>
