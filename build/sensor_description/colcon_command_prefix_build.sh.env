AMENT_PREFIX_PATH=/opt/ros/humble
CMAKE_BUILD_PARALLEL_LEVEL=3
CMAKE_PREFIX_PATH=/opt/OrbbecSDK_v2.4.11/lib:
COLCON=1
CYCLONEDDS_HOME=/home/ros/install
DEBIAN_FRONTEND=noninteractive
DISPLAY=
HOME=/root
HOSTNAME=xterra-orin
LANG=C.UTF-8
LC_ALL=C.UTF-8
LD_LIBRARY_PATH=/opt/ros/humble/opt/rviz_ogre_vendor/lib:/opt/ros/humble/lib/aarch64-linux-gnu:/opt/ros/humble/lib:/usr/local/lib:/home/ros/install/lib
MAKEFLAGS=-j3
NVIDIA_DRIVER_CAPABILITIES=all
NVIDIA_VISIBLE_DEVICES=all
OLDPWD=/home/ros2_ws
OrbbecSDK_DIR=/usr/local/lib/cmake/OrbbecSDK
PATH=/opt/ros/humble/bin:/home/ros/install/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
PWD=/home/ros2_ws/build/sensor_description
PYTHONPATH=/opt/ros/humble/lib/python3.10/site-packages:/opt/ros/humble/local/lib/python3.10/dist-packages
QT_X11_NO_MITSHM=1
